<html>
  <head>
    <title>Crewkort</title>
    <meta name="pdfkit-page_size" content="A4">
    <meta name="pdfkit-orientation" content="Portrait">
    <meta name="pdfkit-margin_top" content="0">
    <meta name="pdfkit-margin_bottom" content="0">
    <meta name="pdfkit-margin_right" content="0">
    <meta name="pdfkit-margin_left" content="0">
    <meta name="pdfkit-dpi" content="96">
    <style>
      body {
        padding: 0;
        margin: 0;
      }
      html {
        padding: 0;
        margin: 0;
      }
      table {
        padding: 0;
        height: 80%;
        width: 96%;
        text-align: center;
        color: red;
        margin: 0 auto;
      }
      td {
        padding: 70px 0;
        margin: 0;
        width: 32%;
        font-family: Impact, sans-serif;
      }
      .al {
        font-size: 24px;
        color: #000000;
      }
      .name {
        font-size: 20px;
        color: #000000;
      }
      .page {
        height: 1123px;
        width: 794px;
        background-image: url(<%= "#{request.protocol}#{request.host_with_port}/custom/#{@access_level.background}" %>);
        background-size: 100%;
        background-repeat: no-repeat;
        background-position: center;
      }
      .card {
        height: 558px;
        vertical-align: top;
        //background-color: rgba(0,255,0,0.5);
      }
      .card div {
        padding-top: 302px;
        padding-left: 28px;
        padding-right: 28px;
        //background-color: rgba(0,0,255,0.5);
      }
      .artist {
        font-size: 26px;
        color: #ffffff;
      }
      @font-face {
        font-family: Impact;
        src: url(<%= "#{request.protocol}#{request.host_with_port}#{ActionController::Base.helpers.asset_path('impact.ttf')}" %>);
      }
    </style>
  </head>
  <body>
    <div class="page">
      <table>
        <tr>
<%
rcounter = 0
ccounter = 0
people = Array.new
if @access_level.name == "Band"
  @bands.each do |band|
    band.band_members.each do |band_member|
      people << band_member
    end
  end
else
  people = @access_level.volunteers
end
people.each do |person|
  if @access_level.name == "Band"
    card_title = @access_level.name.mb_chars.upcase
  else
    if @access_level.name.mb_chars.upcase == person.group.name.mb_chars.upcase
      card_title = @access_level.name.mb_chars.upcase
    else
      card_title = "#{@access_level.name.mb_chars.upcase}<br>#{person.group.name}".html_safe
    end
  end
  if ccounter == 3
    rcounter += 1
%>
        </tr>
<%
    if rcounter == 2
%>
      </table>
    </div>
    <div class="page">
      <table>
<%
      rcounter = 0
    end
%>
        <tr>
<%
    ccounter = 0
  end
%>

          <td class="card">
            <div>
              <span class="al"><%= card_title %></span>
              <br><span class="name"><%= person.short_name %></span>
            </div>
          </td>
<%
  ccounter += 1 
end

while ccounter != 3
%>
          <td></td>
<%
  ccounter += 1
end
if rcounter != 1
%>
        </tr>
        <tr>
<%
end
%>
        </tr>
      </table>
    </div>
  </body>
</html>
